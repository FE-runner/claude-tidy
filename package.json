{
  "name": "claude-tidy",
  "version": "0.1.0",
  "description": "Claude Code 的 skills 和 rules 管理工具",
  "type": "module",
  "bin": {
    "claude-tidy": "./dist/cli.js"
  },
  "scripts": {
    "dev": "node --loader ts-node/esm src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "rules",
    "skills",
    "cli",
    "management"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FE-runner/claude-tidy.git"
  },
  "dependencies": {
    "@inquirer/prompts": "8.3.2",
    "chalk": "5.6.2",
    "diff": "8.0.3"
  },
  "devDependencies": {
    "@types/diff": "7.0.2",
    "@types/node": "25.5.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
